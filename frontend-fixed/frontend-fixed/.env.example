# Base URL of the FastAPI backend's v1 API (see backend/app/core/config.py -> API_V1_PREFIX)
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket base for live boardroom sessions (see backend/app/websocket/router.py)
VITE_WS_URL=ws://localhost:8000/ws

# OAuth client IDs (public, safe to expose in the frontend bundle).
# Redirect URIs are frontend routes — see src/lib/oauth.js for why, and
# register these EXACT URIs in each provider's OAuth app settings:
#   Google:  http://localhost:5173/auth/callback/google  (prod: https://yourdomain.com/auth/callback/google)
#   GitHub:  http://localhost:5173/auth/callback/github  (prod: https://yourdomain.com/auth/callback/github)
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=

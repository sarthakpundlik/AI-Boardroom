# ============================================================
# AI Boardroom — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=AI Boardroom
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_boardroom
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ai_boardroom
DATABASE_URL=postgresql+asyncpg://ai_boardroom:your_secure_password_here@localhost:5432/ai_boardroom

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- Qdrant Vector Store ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ai_boardroom_docs

# --- JWT Authentication ---
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth 2.0 ---
# NOTE: redirect URIs point at the FRONTEND (Vite dev server), not the
# backend. The provider redirects the browser here after consent; the
# frontend page reads ?code= and POSTs it to /auth/{provider}/callback.
# These must match src/lib/oauth.js AND the redirect URI registered in
# each provider's OAuth app settings, exactly.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth/callback/microsoft
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback/github

# --- AI Providers ---
# REQUIRED for boardroom sessions to run — every agent (CFO/CTO/.../CEO)
# calls OpenAI's API via langchain_openai.ChatOpenAI (see app/ai/llm.py).
# Without a real key here, creating a session will always fail with
# "The api_key client option must be set..." as soon as the first agent
# runs. Get a key at https://platform.openai.com/api-keys, paste it below,
# and restart the backend.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_ECONOMY=gpt-4o-mini
# Not currently used by any agent (app/ai/llm.py is OpenAI-only) — safe to
# leave blank unless you extend the code to call these providers directly.
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# --- AWS S3 / S3-Compatible Storage ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-boardroom-uploads
S3_ENDPOINT_URL=

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@aiboardroom.com
SMTP_FROM_NAME=AI Boardroom

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- File Upload ---
MAX_FILE_SIZE_MB=50
MAX_SESSION_SIZE_MB=200
UPLOAD_DIR=./uploads

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

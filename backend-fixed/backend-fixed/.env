# ============================================================
# AI Boardroom — Local Development Configuration
# ============================================================

# --- Application ---
APP_NAME=AI Boardroom
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# --- SQLite (local dev — no PostgreSQL needed) ---
DATABASE_URL=sqlite+aiosqlite:///./ai_boardroom.db

# --- Redis (optional for local dev) ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (optional for local dev) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- JWT ---
JWT_SECRET_KEY=local-dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Provider (REQUIRED for running boardroom sessions — sign up/sign in
# and browsing work without it, but creating a session will fail without a
# valid key since every agent call goes through OpenAI) ---
OPENAI_API_KEY=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

# --- OAuth 2.0 (optional — only needed if you want Google/GitHub sign-in
# buttons to work; email/password sign-up works without any of this) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback/github
